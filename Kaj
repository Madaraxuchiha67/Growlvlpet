--==============================================================--
-- COOLDOWN TRACKING
--==============================================================--
local READY_EPS      = 0.05
local READY_HOLD_SEC = 0.30
local POLL_SEC       = 2.5
local TICK_SEC       = 0.25

local mimicRemain  = nil
local currentSlot  = 1
local readyHoldTimer = 0

if PetCooldownsUpdated then
    PetCooldownsUpdated.OnClientEvent:Connect(function(a, b)
        local lvlKey      = lvlSelectedMimic   and normGuid(lvlSelectedMimic) or nil
        local nmKey       = nmSelectedMimic    and normGuid(nmSelectedMimic) or nil
        local elMimicKey  = elSelectedMimic    and normGuid(elSelectedMimic) or nil
        local elElephKey  = elSelectedElephant and normGuid(elSelectedElephant) or nil

        local function tryMimic(a_, b_, key)
            if a_ and b_ and normGuid(a_) == key then
                local s = pickSeconds(b_)
                if s ~= nil then mimicRemain = s end
                return true
            end
            return false
        end

        local function tryElephant(a_, b_, key)
            if a_ and b_ and normGuid(a_) == key then
                local s = pickSeconds(b_)
                if s ~= nil then elephantRemain = s end
                return true
            end
            return false
        end

        if lvlKey     then tryMimic(a, b, lvlKey) end
        if nmKey      then tryMimic(a, b, nmKey) end
        if elMimicKey then tryMimic(a, b, elMimicKey) end
        if elElephKey then tryElephant(a, b, elElephKey) end

        if type(a) == "table" and not b then
            for k, v in pairs(a) do
                local nk = normGuid(k)
                if nk == lvlKey or nk == nmKey or nk == elMimicKey then
                    local s = pickSeconds(v)
                    if s ~= nil then mimicRemain = s end
                end
                if nk == elElephKey then
                    local s = pickSeconds(v)
                    if s ~= nil then elephantRemain = s end
                end
            end
        end
    end)
end

-- Polling
task.spawn(function()
    while true do
        if RequestPetCooldowns then
            pcall(function() RequestPetCooldowns:FireServer() end)
            if lvlSelectedMimic   then pcall(function() RequestPetCooldowns:FireServer(lvlSelectedMimic) end) end
            if nmSelectedMimic    then pcall(function() RequestPetCooldowns:FireServer(nmSelectedMimic) end) end
            if elSelectedMimic    then pcall(function() RequestPetCooldowns:FireServer(elSelectedMimic) end) end
            if elSelectedElephant then pcall(function() RequestPetCooldowns:FireServer(elSelectedElephant) end) end
        end
        task.wait(POLL_SEC)
    end
end)

currentSlot = getCurrentSlotFromService() or 1

--==============================================================--
-- MAIN LOOP
--==============================================================--
task.spawn(function()
    while true do
        task.wait(TICK_SEC)

        -- Decay timers
        if type(mimicRemain) == "number" then
            mimicRemain = math.max(0, mimicRemain - TICK_SEC)
        end
        if type(elephantRemain) == "number" then
            elephantRemain = math.max(0, elephantRemain - TICK_SEC)
        end

        local realSlot = getCurrentSlotFromService()
        if realSlot then currentSlot = realSlot end

        -- Visual slot (2 and 3 are swapped in DataService)
        local visualSlot = currentSlot
        if currentSlot == 2 then visualSlot = 3
        elseif currentSlot == 3 then visualSlot = 2 end

        local cdTxt   = mimicRemain and string.format("%.2fs", mimicRemain) or "—"
        local slotTxt = "Slot "..visualSlot

        --== LEVELING V1 UI ==--
        do
            local pd = getPetDataFromService(lvlSelectedLeveling)
            local petName = pd and (pd.name ~= "" and pd.name or pd.type) or "—"
            local petAge  = pd and pd.age or 0
            local mut     = pd and pd.mutation or "—"
            local eqTxt   = lvlPetEquipped and "YES" or "NO"
            local qTxt    = #lvlLevelingQueue > 0 and (lvlCurrentQueueIndex.."/"..#lvlLevelingQueue) or "0/0"
            local modeTxt = lvlAutoEnabled and "ON" or "OFF"
            LvlStatusLabel:Set(string.format(
                "Mode: %s | CD: %s | Slot: %s | Pet: %s [%s] | Age: %d/%d | Queue: %s | Done: %d | Equipped: %s",
                modeTxt, cdTxt, slotTxt, petName, mut, petAge, lvlTargetLevel, qTxt, #lvlCompletedPets, eqTxt
            ))
        end

        --== LEVELING V1 LOGIC ==--
        if lvlAutoEnabled and lvlSelectedLeveling then
            local pd      = getPetDataFromService(lvlSelectedLeveling)
            local petAge  = pd and pd.age or 0
            local petName = pd and (pd.name ~= "" and pd.name or pd.type) or "Unknown"
            local petType = pd and pd.type or "Unknown"

            if visualSlot == lvlLevelingSlot and not lvlPetEquipped then
                pcall(function()
                    PetsService:FireServer("EquipPet", lvlSelectedLeveling, CFrame.new())
                end)
                lvlPetEquipped = true
                Notify("Pet Equipped", petName.." ("..lvlCurrentQueueIndex.."/"..#lvlLevelingQueue..")")
            end

            if visualSlot == lvlMimicDilopSlot and lvlPetEquipped then
                pcall(function() PetsService:FireServer("UnequipPet", lvlSelectedLeveling) end)
                lvlPetEquipped = false
            end

            if petAge >= lvlTargetLevel then
                if lvlPetEquipped then
                    pcall(function() PetsService:FireServer("UnequipPet", lvlSelectedLeveling) end)
                    lvlPetEquipped = false
                end
                Notify("Level Complete!", petName.." reached Level "..lvlTargetLevel.."!", 5)
                sendWebhook("Level Complete!","Pet reached target level",5763719,{
                    {name="Pet",value=petName,inline=true},{name="Type",value=petType,inline=true},
                    {name="Level",value=tostring(lvlTargetLevel),inline=true},
                    {name="Queue",value=lvlCurrentQueueIndex.."/"..#lvlLevelingQueue,inline=true},
                })
                table.insert(lvlCompletedPets, lvlSelectedLeveling)
                if lvlCurrentQueueIndex < #lvlLevelingQueue then
                    lvlCurrentQueueIndex = lvlCurrentQueueIndex + 1
                    lvlSelectedLeveling = lvlLevelingQueue[lvlCurrentQueueIndex]
                    local np = getPetDataFromService(lvlSelectedLeveling)
                    local npName = np and (np.name ~= "" and np.name or np.type) or "Unknown"
                    Notify("Next Pet","Now leveling: "..npName.." ("..lvlCurrentQueueIndex.."/"..#lvlLevelingQueue..")",5)
                else
                    lvlAutoEnabled = false
                    LvlAutoToggle:Set(false)
                    Notify("ALL COMPLETE!","All "..#lvlCompletedPets.." pets leveled!",15)
                    sendWebhook("ALL COMPLETE!","All pets leveled!",5814783,{
                        {name="Completed",value=#lvlCompletedPets.." pets",inline=true},
                        {name="Target",value="Level "..lvlTargetLevel,inline=true},
                    })
                end
            end
        end

        --== LEVELING V2 UI ==--
        do
            local pd = getPetDataFromService(v2SelectedLeveling)
            local petName = pd and (pd.name ~= "" and pd.name or pd.type) or "—"
            local petAge  = pd and pd.age or 0
            local mut     = pd and pd.mutation or "—"
            local eqTxt   = v2PetEquipped and "YES" or "NO"
            local qTxt    = #v2LevelingQueue > 0 and (v2CurrentQueueIndex.."/"..#v2LevelingQueue) or "0/0"
            local modeTxt = v2AutoEnabled and "ON" or "OFF"
            V2StatusLabel:Set(string.format(
                "Mode: %s | Triggers: %d | Slot: %s | Pet: %s [%s] | Age: %d/%d | Queue: %s | Done: %d | Equipped: %s",
                modeTxt, v2TriggerCount, slotTxt, petName, mut, petAge, v2TargetLevel, qTxt, #v2CompletedPets, eqTxt
            ))
        end

        --== LEVELING V2 LOGIC ==--
        if v2AutoEnabled and v2SelectedLeveling and #v2LevelingQueue > 0 then
            local pd      = getPetDataFromService(v2SelectedLeveling)
            local petAge  = pd and pd.age or 0
            local petName = pd and (pd.name ~= "" and pd.name or pd.type) or "Unknown"
            local petType = pd and pd.type or "Unknown"

            if not v2PetEquipped then
                pcall(function() PetsService:FireServer("EquipPet", v2SelectedLeveling) end)
                v2PetEquipped = true
            end

            if petAge >= v2TargetLevel then
                if v2PetEquipped then
                    pcall(function() PetsService:FireServer("UnequipPet", v2SelectedLeveling) end)
                    v2PetEquipped = false
                end
                Notify("Level Complete!", petName.." reached Level "..petAge.."!", 5)
                sendWebhook("Level Complete!","Pet reached target level (V2)",5763719,{
                    {name="Pet",value=petName,inline=true},{name="Type",value=petType,inline=true},
                    {name="Level",value=tostring(petAge),inline=true},
                    {name="Triggers",value=tostring(v2TriggerCount),inline=true},
                    {name="Queue",value=v2CurrentQueueIndex.."/"..#v2LevelingQueue,inline=true},
                })
                table.insert(v2CompletedPets, v2SelectedLeveling)
                if v2CurrentQueueIndex < #v2LevelingQueue then
                    v2CurrentQueueIndex = v2CurrentQueueIndex + 1
                    v2SelectedLeveling = v2LevelingQueue[v2CurrentQueueIndex]
                    v2TriggerCount = 0
                    local np = getPetDataFromService(v2SelectedLeveling)
                    local npName = np and (np.name ~= "" and np.name or np.type) or "Unknown"
                    Notify("Next Pet","Now leveling: "..npName.." ("..v2CurrentQueueIndex.."/"..#v2LevelingQueue..")",5)
                else
                    v2AutoEnabled = false
                    V2AutoToggle:Set(false)
                    Notify("ALL COMPLETE!","All "..#v2CompletedPets.." pets leveled!",15)
                    sendWebhook("ALL COMPLETE!","All pets leveled! (V2)",5814783,{
                        {name="Completed",value=#v2CompletedPets.." pets",inline=true},
                        {name="Target",value="Level "..v2TargetLevel,inline=true},
                    })
                end
            end
        end

        --== NIGHTMARE UI ==--
        do
            local pd = getPetDataFromService(nmSelectedLeveling)
            local petName = pd and (pd.name ~= "" and pd.name or pd.type) or "—"
            local petAge  = pd and pd.age or 0
            local mut     = pd and pd.mutation or "—"
            local eqTxt   = nmPetEquipped and "YES" or "NO"
            local qTxt    = #levelingQueue > 0 and (currentQueueIndex.."/"..#levelingQueue) or "0/0"
            local modeTxt = nmAutoEnabled and "ON" or "OFF"
            NmStatusLabel:Set(string.format(
                "Mode: %s | Phase: %s | CD: %s | Slot: %s | Pet: %s [%s] | Age: %d/%d | Queue: %s | Done: %d | Equipped: %s",
                modeTxt, nmPhase, cdTxt, slotTxt, petName, mut, petAge, targetLevel, qTxt, #nmCompletedPets, eqTxt
            ))
        end

        --== NIGHTMARE LEVELING PHASE ==--
        if nmPhase == "LEVELING" and nmAutoEnabled and nmSelectedLeveling then
            local pd      = getPetDataFromService(nmSelectedLeveling)
            local petAge  = pd and pd.age or 0
            local petName = pd and (pd.name ~= "" and pd.name or pd.type) or "Unknown"

            if visualSlot == nmLevelingSlot and not nmPetEquipped then
                pcall(function() PetsService:FireServer("EquipPet", nmSelectedLeveling, CFrame.new()) end)
                nmPetEquipped = true
                Notify("Pet Equipped", petName.." ("..currentQueueIndex.."/"..#levelingQueue..") - Leveling")
            end

            if visualSlot == nmMimicDilopSlot and nmPetEquipped then
                pcall(function() PetsService:FireServer("UnequipPet", nmSelectedLeveling) end)
                nmPetEquipped = false
            end

            if petAge >= targetLevel then
                if nmPetEquipped then
                    pcall(function() PetsService:FireServer("UnequipPet", nmSelectedLeveling) end)
                    nmPetEquipped = false
                end
                nmPhase = "MUTATION"
                nmMutationChecked = false
                Notify("MUTATION PHASE", petName.." reached Lvl "..targetLevel.."! Going to mutation...", 5)
                task.wait(0.5)
                swapTo(visualToInternal(nmMutationSlot))
            end
        end

        --== NIGHTMARE MUTATION PHASE ==--
        if nmPhase == "MUTATION" and nmAutoEnabled and nmSelectedLeveling then
            if visualSlot ~= nmMutationSlot then swapTo(visualToInternal(nmMutationSlot)) end

            if visualSlot == nmMutationSlot and not nmPetEquipped then
                pcall(function() PetsService:FireServer("EquipPet", nmSelectedLeveling, CFrame.new()) end)
                nmPetEquipped = true
                lastMutationResult = nil
                lastMutationName   = nil
                Notify("Mutation: Pet Equipped","Waiting for Headless skill...")
            end

            if nmPetEquipped and lastMutationResult then
                task.wait(1)
                local fp = getPetDataFromService(nmSelectedLeveling)
                local fpName = fp and (fp.name ~= "" and fp.name or fp.type) or "Unknown"

                if lastMutationResult == "Nightmare" then
                    Notify("NIGHTMARE GET!", fpName.." got Nightmare! Moving to next pet...", 8)
                    task.wait(1)
                    pcall(function() PetsService:FireServer("UnequipPet", nmSelectedLeveling) end)
                    nmPetEquipped = false
                    lastMutationResult = nil
                    lastMutationName   = nil
                    table.insert(nmCompletedPets, nmSelectedLeveling)

                    if currentQueueIndex < #levelingQueue then
                        currentQueueIndex = currentQueueIndex + 1
                        nmSelectedLeveling = levelingQueue[currentQueueIndex]
                        nmPhase = "LEVELING"
                        local np = getPetDataFromService(nmSelectedLeveling)
                        local npName = np and (np.name ~= "" and np.name or np.type) or "Unknown"
                        Notify("Next Pet!","Now leveling: "..npName.." ("..currentQueueIndex.."/"..#levelingQueue..")",5)
                        task.wait(1)
                        swapTo(visualToInternal(nmMimicDilopSlot))
                    else
                        nmAutoEnabled = false
                        NmAutoToggle:Set(false)
                        nmPhase = "LEVELING"
                        Notify("ALL COMPLETE!","All "..#nmCompletedPets.." pets got Nightmare!",15)
                    end
                else
                    Notify("Wrong Mutation", fpName.." got "..(lastMutationName or "Unknown")..", cleansing in 2s...", 5)
                    task.wait(2)
                    local ok, msg = applyCleansingShardToPet(nmSelectedLeveling)
                    if ok then
                        Notify("Cleansed!", fpName.." cleansed, back to leveling...", 5)
                        task.wait(2)
                        pcall(function() PetsService:FireServer("UnequipPet", nmSelectedLeveling) end)
                        nmPetEquipped = false
                        lastMutationResult = nil
                        lastMutationName   = nil
                        nmPhase = "LEVELING"
                        task.wait(1)
                        swapTo(visualToInternal(nmMimicDilopSlot))
                    else
                        Notify("Cleanse Failed", msg, 5)
                        lastMutationResult = nil
                        lastMutationName   = nil
                    end
                end
            end
        end

        --== ELEPHANT UI ==--
        do
            local pd = getPetDataFromService(elSelectedLeveling)
            local petName   = pd and (pd.name ~= "" and pd.name or pd.type) or "—"
            local petAge    = pd and pd.age or 0
            local petWeight = pd and pd.currentWeight or 0
            local eqTxt     = elPetEquipped and "YES" or "NO"
            local qTxt      = #elLevelingQueue > 0 and (elCurrentQueueIndex.."/"..#elLevelingQueue) or "0/0"
            local modeTxt   = elAutoEnabled and "ON" or "OFF"
            local mCd = mimicRemain and string.format("%.2fs", mimicRemain) or "—"
            local eCd = elephantRemain and string.format("%.2fs", elephantRemain) or "—"
            ElStatusLabel:Set(string.format(
                "Mode: %s | Phase: %s | Mimic CD: %s | Elephant CD: %s | Slot: %s | Pet: %s | Age: %d/%d | Weight: %.2f KG | Blessings: %d | Queue: %s | Done: %d | Equipped: %s",
                modeTxt, elPhase, mCd, eCd, slotTxt, petName, petAge, elTargetLevel, petWeight, elBlessingCount, qTxt, #elCompletedPets, eqTxt
            ))
        end

        --== ELEPHANT LEVELING PHASE ==--
        if elPhase == "LEVELING" and elAutoEnabled and elSelectedLeveling then
            local pd      = getPetDataFromService(elSelectedLeveling)
            local petAge  = pd and pd.age or 0
            local petName = pd and (pd.name ~= "" and pd.name or pd.type) or "Unknown"

            if visualSlot == elLevelingSlot and not elPetEquipped then
                pcall(function() PetsService:FireServer("EquipPet", elSelectedLeveling, CFrame.new()) end)
                elPetEquipped = true
                Notify("Pet Equipped", petName.." ("..elCurrentQueueIndex.."/"..#elLevelingQueue..") - Leveling")
            end

            if visualSlot == elMimicDilopSlot and elPetEquipped then
                pcall(function() PetsService:FireServer("UnequipPet", elSelectedLeveling) end)
                elPetEquipped = false
            end

            if petAge >= elTargetLevel then
                elPhase = "ELEPHANT"
                lastElephantResult = nil
                lastElephantWeight = nil
                Notify("Level Reached!", petName.." reached Level "..elTargetLevel.."! Switching to Elephant...", 5)
                if elPetEquipped then
                    pcall(function() PetsService:FireServer("UnequipPet", elSelectedLeveling) end)
                    elPetEquipped = false
                end
                task.wait(1)
                swapTo(visualToInternal(elElephantSlot))
            end
        end

        --== ELEPHANT BLESSING PHASE ==--
        if elPhase == "ELEPHANT" and elAutoEnabled and elSelectedLeveling then
            if visualSlot ~= elElephantSlot then swapTo(visualToInternal(elElephantSlot)) end

            if visualSlot == elElephantSlot and not elPetEquipped then
                pcall(function() PetsService:FireServer("EquipPet", elSelectedLeveling, CFrame.new()) end)
                elPetEquipped = true
                lastElephantResult = nil
                lastElephantWeight = nil
                Notify("Elephant: Pet Equipped","Waiting for Jumbo Blessing...")
            end

            if elPetEquipped and lastElephantResult then
                task.wait(1)
                local fp = getPetDataFromService(elSelectedLeveling)
                local fpName   = fp and (fp.name ~= "" and fp.name or fp.type) or "Unknown"
                local fpType   = fp and fp.type or "Unknown"
                local fpWeight = fp and fp.currentWeight or 0

                if lastElephantResult == "MaxWeight" then
                    Notify("MAX WEIGHT!", fpName.." reached max weight cap!", 8)
                    sendWebhook("Max Weight Reached!","Pet reached max weight cap!",16776960,{
                        {name="Pet",value=fpName,inline=true},{name="Type",value=fpType,inline=true},
                        {name="Weight",value=string.format("%.2f KG",fpWeight),inline=true},
                        {name="Blessings",value=tostring(elBlessingCount),inline=true},
                        {name="Queue",value=elCurrentQueueIndex.."/"..#elLevelingQueue,inline=true},
                    })
                    task.wait(1)
                    pcall(function() PetsService:FireServer("UnequipPet", elSelectedLeveling) end)
                    elPetEquipped = false
                    lastElephantResult = nil
                    lastElephantWeight = nil
                    table.insert(elCompletedPets, elSelectedLeveling)

                    if elCurrentQueueIndex < #elLevelingQueue then
                        elCurrentQueueIndex = elCurrentQueueIndex + 1
                        elSelectedLeveling = elLevelingQueue[elCurrentQueueIndex]
                        elPhase = "LEVELING"
                        elBlessingCount = 0
                        local np = getPetDataFromService(elSelectedLeveling)
                        local npName = np and (np.name ~= "" and np.name or np.type) or "Unknown"
                        Notify("Next Pet","Now leveling: "..npName.." ("..elCurrentQueueIndex.."/"..#elLevelingQueue..")",5)
                        task.wait(1)
                        swapTo(visualToInternal(elMimicDilopSlot))
                    else
                        elAutoEnabled = false
                        ElAutoToggle:Set(false)
                        elPhase = "LEVELING"
                        Notify("ALL COMPLETE!","All "..#elCompletedPets.." pets reached max weight!",15)
                        sendWebhook("ALL COMPLETE!","All pets reached max weight!",5814783,{
                            {name="Completed",value=#elCompletedPets.." pets",inline=true},
                        })
                    end

                elseif lastElephantResult == "Blessed" then
                    elBlessingCount = elBlessingCount + 1
                    local wTxt = lastElephantWeight and string.format("%.2f KG", lastElephantWeight) or "N/A"
                    Notify("Blessed!", fpName.." blessed! Weight: "..wTxt.." (Blessing #"..elBlessingCount..")", 5)
                    task.wait(1)
                    pcall(function() PetsService:FireServer("UnequipPet", elSelectedLeveling) end)
                    elPetEquipped = false
                    lastElephantResult = nil
                    lastElephantWeight = nil
                    elPhase = "LEVELING"
                    task.wait(1)
                    swapTo(visualToInternal(elMimicDilopSlot))
                end
            end
        end

        --== AUTO SLOT SWITCH ==--
        local isLvlActive = lvlAutoEnabled
        local isNmActive  = nmAutoEnabled and nmPhase == "LEVELING"
        local isElActive  = elAutoEnabled and elPhase == "LEVELING"

        if not isLvlActive and not isNmActive and not isElActive then
            readyHoldTimer = 0
        else
            local dilopSlot, levelSlot
            if isNmActive then
                dilopSlot = nmMimicDilopSlot; levelSlot = nmLevelingSlot
            elseif isElActive then
                dilopSlot = elMimicDilopSlot; levelSlot = elLevelingSlot
            else
                dilopSlot = lvlMimicDilopSlot; levelSlot = lvlLevelingSlot
            end

            if visualSlot == dilopSlot then
                if mimicRemain and mimicRemain <= READY_EPS then
                    readyHoldTimer = readyHoldTimer + TICK_SEC
                    if readyHoldTimer >= READY_HOLD_SEC then
                        swapTo(visualToInternal(levelSlot))
                        readyHoldTimer = 0
                    end
                else
                    readyHoldTimer = 0
                end
            elseif visualSlot == levelSlot then
                if mimicRemain and mimicRemain > READY_EPS then
                    swapTo(visualToInternal(dilopSlot))
                    readyHoldTimer = 0
                end
            end
        end
    end
end)

